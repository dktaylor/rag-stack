# Open WebUI base URL (change if running on a different host/port)
OPENWEBUI_URL=http://localhost:3000

# JWT token — get from Open WebUI: Settings → Account → API Keys → Create new secret key
# Tokens expire; rotate before the expiry date shown in the UI.
OPENWEBUI_TOKEN=

# Ollama inference endpoint (used by Open WebUI for chat + completions)
# Set to a remote host if Ollama is not running locally
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Embedding model used by Open WebUI / Qdrant
# BAAI/bge-large-en-v1.5 produces 1024-dim vectors (good balance of quality + speed)
# Change only if you want a different embedding model — existing KBs must be re-indexed
RAG_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Set to "1" to auto-detect project slug and framework from the MCP server's working directory
RAG_CWD_DETECT=1
