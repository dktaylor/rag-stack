#!/usr/bin/env bash
# fetch-model — Download HuggingFace models listed in models.conf to the
# rag-stack models directory so the Open WebUI container can start offline.
#
# Usage:
#   fetch-model                # download all huggingface models in models.conf
#   fetch-model --all          # same as above
#   fetch-model --list         # list configured models without downloading
#   fetch-model <model-id>     # download a specific model by ID
#   fetch-model --help
#
# Models land in $MODELS_DIR (default: /opt/rag-stack/models/).
# The Open WebUI container mounts this directory at /root/.cache/huggingface/hub/
# and starts with HF_HUB_OFFLINE=1.
set -euo pipefail

RAG_DIR="${RAG_INSTALL_DIR:-/opt/rag-stack}"
MODELS_DIR="${RAG_MODELS_DIR:-${RAG_DIR}/models}"
CONF_FILE="${RAG_DIR}/models.conf"

# ---- colour helpers ----------------------------------------------------------
if [[ -t 1 ]]; then B=$'\e[1m'; G=$'\e[32m'; Y=$'\e[33m'; R=$'\e[31m'; X=$'\e[0m'
else B=""; G=""; Y=""; X=""; R=""; fi
info()  { printf "${B}==> ${X}%s\n" "$*"; }
ok()    { printf "  ${G}[ok]${X} %s\n" "$*"; }
warn()  { printf "  ${Y}[warn]${X} %s\n" "$*"; }
err()   { printf "  ${R}[error]${X} %s\n" "$*" >&2; }

# ---- parse models.conf -------------------------------------------------------
# Returns lines matching "huggingface" sources, stripping comments/blanks.
_hf_models() {
    grep -v '^\s*#' "$CONF_FILE" 2>/dev/null \
        | grep -v '^\s*$' \
        | grep 'huggingface' \
        | awk '{print $2}'
}

_all_models() {
    grep -v '^\s*#' "$CONF_FILE" 2>/dev/null \
        | grep -v '^\s*$' \
        | awk '{printf "%-30s %s\n", $1, $2}'
}

# ---- ensure huggingface_hub is available ------------------------------------
_ensure_hf_hub() {
    if python3 -c "import huggingface_hub" 2>/dev/null; then
        return 0
    fi
    info "Installing huggingface_hub (required for downloads)..."
    pip3 install --quiet huggingface_hub || {
        err "Could not install huggingface_hub. Run: pip3 install huggingface_hub"
        exit 1
    }
}

# ---- download a single model ------------------------------------------------
_fetch_one() {
    local model_id="$1"
    info "Fetching: ${model_id}"
    mkdir -p "$MODELS_DIR"

    python3 - <<PYEOF
import sys
from huggingface_hub import snapshot_download

try:
    path = snapshot_download(
        repo_id="${model_id}",
        cache_dir="${MODELS_DIR}",
        ignore_patterns=["*.msgpack", "*.h5", "flax_model*", "tf_model*", "rust_model*"],
    )
    print(f"  Saved to: {path}")
except Exception as e:
    print(f"  ERROR: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
    ok "${model_id}"
}

# ---- commands ----------------------------------------------------------------
cmd="${1:---all}"

case "$cmd" in
  --help|-h)
    cat <<'EOF'
fetch-model — Download HuggingFace models for the rag-stack

Usage:
  fetch-model [--all]        Download all huggingface models in models.conf
  fetch-model --list         List all configured models (no download)
  fetch-model <model-id>     Download a specific model (e.g. BAAI/bge-large-en-v1.5)
  fetch-model --help

Config:  /opt/rag-stack/models.conf
Models:  /opt/rag-stack/models/

After fetching, restart Open WebUI to pick up new models:
  rag restart open-webui

If you change the embedding model, re-index all projects:
  rag index ~/Projects/<name>
EOF
    ;;
  --list)
    if [ ! -f "$CONF_FILE" ]; then
        warn "No models.conf found at $CONF_FILE"
        exit 1
    fi
    echo "${B}Configured models (${CONF_FILE}):${X}"
    echo ""
    _all_models
    echo ""
    echo "HuggingFace models staged for download:"
    _hf_models | while read -r m; do
        local_path="${MODELS_DIR}/models--$(echo "$m" | tr '/' '--')"
        if [ -d "$local_path" ]; then
            printf "  ${G}[cached]${X} %s\n" "$m"
        else
            printf "  ${Y}[missing]${X} %s\n" "$m"
        fi
    done
    ;;
  --all)
    if [ ! -f "$CONF_FILE" ]; then
        warn "No models.conf found at $CONF_FILE — nothing to fetch."
        exit 1
    fi
    mapfile -t models < <(_hf_models)
    if [ ${#models[@]} -eq 0 ]; then
        warn "No huggingface models found in $CONF_FILE."
        exit 0
    fi
    _ensure_hf_hub
    for model in "${models[@]}"; do
        _fetch_one "$model"
    done
    echo ""
    ok "All models downloaded to ${MODELS_DIR}"
    echo "  Restart Open WebUI to load them: rag restart open-webui"
    ;;
  -*)
    err "Unknown option: $cmd"
    echo "Run 'fetch-model --help' for usage." >&2
    exit 1
    ;;
  *)
    # Treat as a model ID
    _ensure_hf_hub
    _fetch_one "$cmd"
    echo ""
    ok "Downloaded to ${MODELS_DIR}"
    echo "  Restart Open WebUI to load it: rag restart open-webui"
    ;;
esac
