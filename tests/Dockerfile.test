FROM python:3.11-slim
WORKDIR /app
COPY tests/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
# mcp/, tiers.json, and tests/ are bind-mounted by docker-compose.test.yml
# so code changes don't require a rebuild
CMD ["pytest", "/app/tests/", "-v", "--tb=short", "--no-header"]
