# Open WebUI base URL (change if running on a different host/port)
OPENWEBUI_URL=http://localhost:3000

# API token — auto-generated by 'rag start' on first run (via 'rag bootstrap').
# Tokens survive container/volume rebuilds as long as WEBUI_SECRET_KEY stays the same.
# To rotate manually: run 'rag bootstrap' (generates a new sk-* key and updates this file).
OPENWEBUI_TOKEN=

# Admin account credentials — written by 'rag bootstrap'. Do not set manually.
OPENWEBUI_EMAIL=
OPENWEBUI_PASSWORD=

# Ollama inference endpoint (used by Open WebUI for chat + completions)
# Set to a remote host if Ollama is not running locally
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Embedding model used by Open WebUI / Qdrant
# Default is nomic-embed-text via Ollama (768-dim, no container network required).
# Change only if you want a different embedding model — existing KBs must be re-indexed.
RAG_EMBEDDING_MODEL=nomic-embed-text

# Open WebUI JWT signing key — set once on first install, never change.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# If blank, Open WebUI generates a random key stored inside the volume.
# Setting it explicitly means tokens survive volume wipes and container rebuilds.
WEBUI_SECRET_KEY=

# Set to "1" to auto-detect project slug and framework from the MCP server's working directory
RAG_CWD_DETECT=1
