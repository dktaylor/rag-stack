[Unit]
Description=RAG Stack (Open WebUI + Qdrant)
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/rag-stack
EnvironmentFile=-/opt/rag-stack/.env
ExecStart=/usr/bin/docker compose -f /opt/rag-stack/docker-compose.yml up -d
ExecStop=/usr/bin/docker compose -f /opt/rag-stack/docker-compose.yml down
TimeoutStartSec=120
TimeoutStopSec=30
User=devuser
Group=docker

[Install]
WantedBy=multi-user.target
